{
  "name": "getpaid-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "prisma generate && tsc",
    "db:push": "dotenv -e .env -- prisma db push --schema ./prisma/schema.prisma",
    "db:seed": "dotenv -e .env -- tsx prisma/seed.ts",
    "db:reset": "dotenv -e .env -- prisma migrate reset --force --schema ./prisma/schema.prisma",
    "db:studio": "dotenv -e .env -- prisma studio --schema ./prisma/schema.prisma",
    "db:generate": "dotenv -e .env -- prisma generate --schema ./prisma/schema.prisma",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.4.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "nanoid": "^3.3.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.5",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
